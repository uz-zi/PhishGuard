# ── Virtual Environment ──────────────────────────────────────
.venv/
venv/
env/

# ── Python Cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Raw Data (too large for GitHub) ──────────────────────────
data/raw/new_data_urls.csv
data/raw/top-1m.csv

# ── Processed Data (auto-generated by scripts) ───────────────
data/processed/

# ── Trained Models (too large for GitHub) ────────────────────
model/model.pkl
model/lr_model.pkl

# ── Keep these small model files ─────────────────────────────
!model/features.json
!model/model_results.json

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Environment Variables ─────────────────────────────────────
.env
.env.local

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Keep empty folders ───────────────────────────────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!model/.gitkeep